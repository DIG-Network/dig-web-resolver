{
  "name": "@dignetwork/dig-web-resolver",
  "version": "0.1.0",
  "description": "A CDN-droppable <script> that teaches any webpage to resolve urn:dig:chia: and chia:// references in-page, fail-closed, via @dignetwork/dig-urn-resolver.",
  "license": "GPL-2.0-only",
  "author": "DIG Network",
  "repository": {
    "type": "git",
    "url": "https://github.com/DIG-Network/dig-web-resolver.git"
  },
  "keywords": [
    "dig",
    "chia",
    "urn",
    "resolver",
    "loader",
    "cdn",
    "wasm"
  ],
  "type": "module",
  "main": "./dist/dig-web-resolver.esm.js",
  "module": "./dist/dig-web-resolver.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dig-web-resolver.esm.js",
      "default": "./dist/dig-web-resolver.esm.js"
    },
    "./iife": "./dist/dig-web-resolver.iife.js"
  },
  "files": [
    "dist",
    "README.md",
    "SPEC.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/dig-web-resolver.iife.js",
    "./dist/dig-web-resolver.iife.external-wasm.js"
  ],
  "scripts": {
    "gen:wasm": "node scripts/gen-wasm.mjs",
    "build": "npm run gen:wasm && node scripts/build.mjs && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dignetwork/dig-urn-resolver": "^0.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "@vitest/coverage-v8": "^2.1.2",
    "esbuild": "^0.24.0",
    "eslint": "^9.12.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
